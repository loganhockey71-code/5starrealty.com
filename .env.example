PORT=8000
ADMIN_USERNAME=admin
# Generate with: npm run hash-password -- "yourPasswordHere"
ADMIN_PASSWORD_HASH=
SESSION_SECRET=change-this-to-a-long-random-string

# Only needed in production (e.g. Render) with a persistent disk mounted.
# Leave unset for local dev — defaults to ./data and ./uploads.
# DATA_DIR=/var/data/app-data
# UPLOADS_DIR=/var/data/uploads
